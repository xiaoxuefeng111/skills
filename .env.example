# AAR 发布自动化 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
#
# 使用方法:
#   1. 复制: cp .env.example .env
#   2. 编辑: 填入实际凭据值
#   3. 加载: source .env 或由程序自动加载
#
# ⚠️ 注意: .env 文件包含敏感信息，请勿提交到 Git！

# ============================================
# TFS Git 凭据（必需）
# ============================================
# TFS Git PAT Token，用于 FlutterBuild 仓库认证
# 获取方式: TFS → 用户设置 → Personal Access Tokens → 新建 Token
# 所需权限: 代码（读取、写入）
TFS_GIT_TOKEN=

# TFS Git 仓库 URL（可选，使用默认值）
# TFS_REPO_URL=http://192.168.40.200:8080/tfs/OpenSDK/_git/FlutterBuild

# ============================================
# Jenkins 凭据（必需）
# ============================================
# Jenkins 用户名
JENKINS_USER=

# Jenkins API Token
# 获取方式: Jenkins → 用户 → 配置 → API Token → 添加新 Token
JENKINS_TOKEN=

# ============================================
# Jenkins URL 配置（可选）
# ============================================
# 标准 Jenkins URL（默认: http://jenkins.company.com:8080）
# JENKINS_URL=

# TdxFlutter 专用 Jenkins URL（默认: http://192.168.30.28:8080）
# JENKINS_URL_TDXFLUTTER=

# ============================================
# 验证凭据
# ============================================
# 运行以下命令验证凭据是否正确配置:
#   python scripts/tdx_publish.py --check-credentials